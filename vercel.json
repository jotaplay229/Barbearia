{
  "cleanUrls": true,
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/cron-lembretes",
      "schedule": "0 * * * *"
    }
  ],
  "rewrites": [
    { "source": "/admin-saas", "destination": "/admin-saas.html" },
    { "source": "/painel", "destination": "/painel.html" },
    { "source": "/agendar", "destination": "/agendar.html" },
    { "source": "/b/:slug", "destination": "/agendar.html" }
  ]
}
