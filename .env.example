# Supabase
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=SUA_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=SUA_SUPABASE_SERVICE_ROLE_KEY

# E-mails que podem acessar /admin-saas, separados por virgula.
SAAS_ADMIN_EMAILS=seu-email@gmail.com

# URL publica da Vercel, usada em links enviados por WhatsApp.
APP_URL=https://seu-projeto.vercel.app

# Opcional: se preencher, chame /api/cron-lembretes?secret=SUA_CHAVE
CRON_SECRET=

# Evolution API global do SaaS.
# O dono da barbearia informa apenas o telefone no painel.
# A instancia e criada automaticamente como: barbearia-slug-da-loja.
EVOLUTION_API_URL=https://evolution.seudominio.com
EVOLUTION_API_KEY=SUA_GLOBAL_API_KEY
EVOLUTION_INSTANCE_PREFIX=barbearia
